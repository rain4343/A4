# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/ediwan
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ediwan

# ─── API Server ──────────────────────────────────────────────────────────────
# Port the Express backend listens on (default: 8080)
PORT=8080

# Secret used to sign session cookies — use any long random string locally
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Frontend (optional) ─────────────────────────────────────────────────────
# Port the Vite dev server listens on (default: 5173)
# PORT=5173
